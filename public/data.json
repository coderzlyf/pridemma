        "hero": {
            "title": "Forged by Passion. Defined by Pride.",
            "description": "Empowering individuals through the discipline and community of martial arts and fitness.",
            "bgImage": "https://lh3.googleusercontent.com/aida-public/AB6AXuBR9wGTAcyA9JOse6B4Qz5NLofS2nN-P4DlXlehCxOaow2OAKK3BEW2fND_A1nCr44xIAg0LwG9gzbS87ytz4g1gEyJLdNva-AD-qcI_zp4RwkFm9h1l4FK-qwoL0AdZKur4juMH200o3uLYJjvtF86vtfBUWNRb3KBlou7AJYg3p1RVD4sOSCRAiOO0-4x5Hitq45WWkLmRRutbCPk6KbOyiIHt5CwHNc4MnrO5HvMJHSR7c2fYczWtJLE90FGaj98cSVkOlyfSRg"
